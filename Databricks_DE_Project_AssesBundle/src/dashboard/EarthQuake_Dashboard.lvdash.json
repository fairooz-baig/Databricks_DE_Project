{
  "datasets": [
    {
      "name": "1b8f95cd",
      "displayName": "EarthQuake_detail",
      "queryLines": [
        "select * from silver.earthquake_data_final;"
      ],
      "catalog": "youtube_prod",
      "schema": "default"
    },
    {
      "name": "381a5a5d",
      "displayName": "EarthQuake_type",
      "queryLines": [
        "SELECT\r\n",
        "  COUNT(*) AS total_magnitude_bucket,\r\n",
        "  magnitude_bucket\r\n",
        "FROM\r\n",
        "  (\r\n",
        "    SELECT\r\n",
        "      CASE\r\n",
        "        WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "        WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2-3)'\r\n",
        "        WHEN mag BETWEEN 3 AND 4 THEN 'Light (3-4)'\r\n",
        "        ELSE 'Moderate (4+)'\r\n",
        "      END AS magnitude_bucket\r\n",
        "    FROM\r\n",
        "      silver.earthquake_data_final\r\n",
        "  )\r\n",
        "GROUP BY\r\n",
        "  magnitude_bucket"
      ],
      "catalog": "youtube_prod",
      "schema": "silver"
    },
    {
      "name": "7d396abb",
      "displayName": "EarthQuake_country",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) AS event_count,\n",
        "  CASE\n",
        "    WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\n",
        "    ELSE split(place, ', ')[1]\n",
        "  END AS country\n",
        "FROM\n",
        "  (\n",
        "    SELECT\n",
        "      time,\n",
        "      title,\n",
        "      mag,\n",
        "      longitude,\n",
        "      place,\n",
        "      latitude\n",
        "    FROM\n",
        "      earthquake_data_final\n",
        "  ) t\n",
        "GROUP BY\n",
        "  CASE\n",
        "    WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\n",
        "    ELSE split(place, ', ')[1]\n",
        "  END"
      ],
      "catalog": "youtube_prod",
      "schema": "silver"
    }
  ],
